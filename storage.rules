rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && firestore.get(
          /databases/(default)/documents/users/$(request.auth.uid)
        ).data.role == 'admin';
    }

    match /product_images/{fileName} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /category_images/{fileName} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /user_avatars/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && fileName == request.auth.uid + '.jpg';
    }
  }
}
